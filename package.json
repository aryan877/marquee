{
  "name": "marquee",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=@marquee/web",
    "dev:worker": "turbo run dev --filter=@marquee/worker",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:gen": "pnpm --filter @marquee/db gen",
    "db:push": "pnpm --filter @marquee/db push",
    "db:migrate": "pnpm --filter @marquee/db migrate",
    "db:reset": "pnpm --filter @marquee/db reset"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
