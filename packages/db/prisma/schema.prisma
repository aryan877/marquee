// ─────────────────────────────────────────────────────────────────────
// Marquee — table DDL only.
// RLS, grants, RPCs, triggers, pgmq queues live in supabase/migrations.
// Never model auth.users (Supabase owns that schema; the auth↔profiles
// bridge lives as triggers in 10_rls_and_triggers.sql).
// ─────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Users ───
// auth.users INSERT trigger creates a profile row;
// auth.users DELETE trigger cascades back. See 10_rls_and_triggers.sql.

model profiles {
  id                   String    @id @db.Uuid
  email                String
  username             String?
  avatar_url           String?
  // FREE | FOUNDER. TEXT not enum — adding plans is a code-only change
  // in @marquee/shared/billing. /api/checkout validates against PLANS
  // before writing.
  plan                 String    @default("FREE")
  // Per-period quota counter (e.g. autopilot posts used this month).
  posts_used_period    Int       @default(0)
  period_ends_at       DateTime? @db.Timestamptz
  cancel_at_period_end Boolean   @default(false)
  banned_at            DateTime? @db.Timestamptz
  ban_reason           String?
  dodo_customer_id     String?
  dodo_subscription_id String?
  created_at           DateTime  @default(now()) @db.Timestamptz
  updated_at           DateTime  @default(now()) @updatedAt @db.Timestamptz

  brands           brands[]
  whatsapp_account whatsapp_accounts?

  @@index([dodo_subscription_id])
}

// ─── Brands (user's brand profile — voice, colors, fonts, guidelines) ───

model brands {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String   @db.Uuid
  name            String
  handle          String?
  description     String?
  industry        String?
  target_audience String?
  // {tone, style, sample_lines[], banned_phrases[]}
  voice           Json     @default("{}")
  // {primary, secondary, accent, bg, fg} — hex strings
  palette         Json     @default("{}")
  // {heading, body} — google font names
  fonts           Json     @default("{}")
  logo_url        String?
  // {do[], dont[], vocabulary[], hashtags[]}
  guidelines      Json     @default("{}")
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now()) @db.Timestamptz
  updated_at      DateTime @default(now()) @updatedAt @db.Timestamptz

  user            profiles          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  social_accounts social_accounts[]
  campaigns       campaigns[]
  content_jobs    content_jobs[]

  @@index([user_id])
}

// ─── Connected social accounts (Playwright persistent sessions) ───

model social_accounts {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  brand_id     String         @db.Uuid
  platform     SocialPlatform
  handle       String
  // pgcrypto-encrypted Playwright storage_state JSON
  session_enc  Bytes?
  is_active    Boolean        @default(true)
  last_post_at DateTime?      @db.Timestamptz
  created_at   DateTime       @default(now()) @db.Timestamptz
  updated_at   DateTime       @default(now()) @updatedAt @db.Timestamptz

  brand brands @relation(fields: [brand_id], references: [id], onDelete: Cascade)

  @@unique([brand_id, platform])
  @@index([brand_id])
}

model whatsapp_accounts {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String    @unique @db.Uuid
  phone_e164        String?
  display_name      String?
  jid               String?
  session_enc       Bytes?
  status            String    @default("DISCONNECTED")
  last_qr_at        DateTime? @db.Timestamptz
  last_connected_at DateTime? @db.Timestamptz
  last_send_at      DateTime? @db.Timestamptz
  created_at        DateTime  @default(now()) @db.Timestamptz
  updated_at        DateTime  @default(now()) @updatedAt @db.Timestamptz

  user profiles @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([status])
}

enum SocialPlatform {
  INSTAGRAM
  TIKTOK
  TWITTER // X
  LINKEDIN
  FACEBOOK
  YOUTUBE
  BLUESKY
  THREADS
  PINTEREST
  GOOGLE_BUSINESS
  MASTODON
  DISCORD
  TELEGRAM
}

// ─── Campaigns (autopilot schedules per brand) ───

model campaigns {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  brand_id        String           @db.Uuid
  name            String
  content_type    ContentType
  cron_expression String?
  next_run_at     DateTime?        @db.Timestamptz
  topic_pool      String[]         @default([])
  platforms       SocialPlatform[] @default([])
  autopilot       Boolean          @default(false)
  // Founder-Pass-gated. When true, finished jobs skip REVIEW and go straight
  // to POSTING. Enforced at submit time against profiles.plan.
  auto_publish    Boolean          @default(false)
  active          Boolean          @default(true)
  created_at      DateTime         @default(now()) @db.Timestamptz
  updated_at      DateTime         @default(now()) @updatedAt @db.Timestamptz

  brand brands @relation(fields: [brand_id], references: [id], onDelete: Cascade)

  @@index([brand_id])
  @@index([active, next_run_at])
}

enum ContentType {
  POSTER
  VIDEO
  CAROUSEL
  REEL
}

// ─── Content jobs (one row per generation; consumed by worker via PGMQ) ───

model content_jobs {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String           @db.Uuid
  brand_id       String           @db.Uuid
  campaign_id    String?          @db.Uuid
  status         ContentJobStatus @default(PENDING)
  content_type   ContentType
  topic          String?
  caption        String?
  hashtags       String[]         @default([])
  platforms      SocialPlatform[] @default([])
  output_url     String?
  output_key     String?
  thumbnail_url  String?
  posted_at      DateTime?        @db.Timestamptz
  approved_at    DateTime?        @db.Timestamptz
  // Snapshotted at submit so queue ordering stays deterministic even if
  // the user upgrades/cancels mid-wait.
  queue_plan     String           @default("FREE")
  queue_priority Int              @default(0)
  error_message  String?
  // arbitrary per-pipeline scratch data (frame counts, asset urls, etc.)
  metadata       Json             @default("{}")
  created_at     DateTime         @default(now()) @db.Timestamptz
  completed_at   DateTime?        @db.Timestamptz

  brand        brands                  @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  events       progress_events[]
  artifacts    content_job_artifacts[]
  usage_events agent_usage_events[]

  @@index([user_id, created_at(sort: Desc)])
  @@index([status, queue_priority(sort: Desc), created_at, id])
  @@index([brand_id, created_at(sort: Desc)])
}

enum ContentJobStatus {
  PENDING
  GENERATING
  RENDERING
  REVIEW
  POSTING
  POSTED
  FAILED
  CANCELLED
}

// ─── Progress events — append-only audit log for the WS stream ───
// The worker streams these to the Studio over a raw WebSocket on :4001.
// Rows here are for replay/debug only; clients never SELECT this table.

model progress_events {
  id         BigInt   @id @default(autoincrement())
  job_id     String   @db.Uuid
  // canonical step ids: "queued" | "research" | "script" | "image" |
  // "render" | "review" | "post" | "complete" | "error"
  step       String
  message    String
  progress   Float?
  // optional preview/intermediate artifact urls
  payload    Json?
  created_at DateTime @default(now()) @db.Timestamptz

  job content_jobs @relation(fields: [job_id], references: [id], onDelete: Cascade)

  @@index([job_id, created_at])
}

model content_job_artifacts {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  job_id     String   @db.Uuid
  kind       String
  role       String
  iteration  Int      @default(0)
  url        String?
  key        String?
  mime_type  String?
  width      Int?
  height     Int?
  duration_s Float?
  metadata   Json     @default("{}")
  created_at DateTime @default(now()) @db.Timestamptz

  job content_jobs @relation(fields: [job_id], references: [id], onDelete: Cascade)

  @@index([job_id, created_at])
  @@index([job_id, role, created_at(sort: Desc)])
}

model agent_usage_events {
  id                 BigInt   @id @default(autoincrement())
  job_id             String?  @db.Uuid
  provider           String
  model              String
  purpose            String
  input_tokens       Int      @default(0)
  output_tokens      Int      @default(0)
  estimated_cost_usd Decimal  @default(0) @db.Decimal(10, 6)
  metadata           Json     @default("{}")
  created_at         DateTime @default(now()) @db.Timestamptz

  job content_jobs? @relation(fields: [job_id], references: [id], onDelete: SetNull)

  @@index([created_at])
  @@index([job_id, created_at])
}

// ─── Dodo webhook idempotency + audit ───

model dodo_webhook_events {
  webhook_id    String    @id
  event_type    String
  payload       Json
  processed_at  DateTime? @db.Timestamptz
  error_message String?
  created_at    DateTime  @default(now()) @db.Timestamptz
}

// ─── Worker heartbeat (singleton, updated each poll) ───

model worker_heartbeat {
  id         Int      @id @default(1)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz
}
