{
  "name": "@marquee/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/database.types.ts",
    "./client": "./src/client.ts",
    "./server": "./src/server.ts"
  },
  "scripts": {
    "gen": "tsx scripts/gen-types.ts",
    "gen:supabase": "supabase gen types typescript --project-id $SUPABASE_PROJECT_REF > src/database.types.ts",
    "push": "dotenv -e ../../.env -- prisma db push",
    "migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "reset": "dotenv -e ../../.env -- prisma migrate reset",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "apply:sql": "tsx scripts/apply-migrations.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "dotenv-cli": "^8.0.0",
    "prisma": "^7.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
